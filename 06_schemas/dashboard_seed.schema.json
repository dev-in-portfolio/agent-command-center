{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "const": "Agent Command Center"
    },
    "families": {
      "type": "array",
      "minItems": 175,
      "maxItems": 175,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "integer"
          },
          "label": {
            "type": "string"
          },
          "folder": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "const": "shell_created"
          }
        },
        "required": [
          "id",
          "label",
          "folder",
          "status"
        ]
      }
    }
  },
  "required": [
    "title",
    "families"
  ]
}