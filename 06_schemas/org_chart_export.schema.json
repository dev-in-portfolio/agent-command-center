{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "system_name": {
      "type": "string",
      "const": "Agent Command Center"
    },
    "version": {
      "type": "string",
      "const": "0.1.0"
    },
    "total_families": {
      "type": "number",
      "const": 175
    },
    "families": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "manager": {
            "type": "string"
          },
          "scribe": {
            "type": "string"
          },
          "auditor": {
            "type": "string"
          },
          "folder": {
            "type": "string"
          },
          "family_file": {
            "type": "string"
          },
          "readme": {
            "type": "string"
          },
          "departments": {
            "type": "array"
          }
        },
        "required": [
          "id",
          "name",
          "manager",
          "scribe",
          "auditor",
          "folder",
          "family_file",
          "readme",
          "departments"
        ]
      }
    }
  },
  "required": [
    "system_name",
    "version",
    "total_families",
    "families"
  ]
}