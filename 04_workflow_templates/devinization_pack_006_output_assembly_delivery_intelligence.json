{
  "extension_id": "devinization_pack_006_output_assembly_delivery_intelligence",
  "extension_name": "Devinization Pack 6 — Output Assembly & Delivery Intelligence",
  "mode": "overlay",
  "preserves_locked_baseline": true,
  "baseline_status": "175-family expansion locked",
  "depends_on": [
    "family_007_devinized_engineering_overload",
    "devinization_pack_001_command_brain",
    "devinization_pack_002_runtime_routing_work_control",
    "devinization_pack_003_prompt_memory_context_architecture",
    "devinization_pack_004_execution_safety_tools_recovery",
    "devinization_pack_005_quality_standards_human_review"
  ],
  "included_families": [
    {
      "family_id": 138,
      "family_name": "Output Assembly, Synthesis & Final Answer Design"
    },
    {
      "family_id": 82,
      "family_name": "Version Control, Releases & Change Management"
    }
  ],
  "purpose": "Define the final-output and delivery layer that turns routed work, agent outputs, evidence, validation results, changed-file proof, review decisions, and user preferences into clean, usable, audience-ready deliverables. This pack governs how the system assembles final answers, avoids burying the important part, preserves proof, labels versions, tracks changes, and packages work for Devin, clients, portfolio use, or future runtime handoff.",
  "core_operating_philosophy": "The Agent Command Center remains a massive command civilization with selective live deployment. The whole 175-family agency remains available for awareness, routing, governance, memory, standards, review, and output intelligence. This pack does not shrink the art piece. This pack defines how completed work becomes clear, useful, versioned, packaged, and ready for the intended audience. Delivery is only real when it is useful to the human at the other end.",
  "activation_rule": "Use this pack when the user says or implies: final answer, assemble output, synthesize this, make it copy paste, format this, make it usable, front-load the answer, do not bury the important part, deliverable, package this, version this, release notes, changelog, final report, commit proof, changed files, validator summary, client-ready, portfolio-ready, export-ready, presentation-ready, dashboard-ready, lock report, next step summary, what changed, ready to ship, delivery intelligence.",
  "delivery_layers": [
    {
      "layer": 1,
      "name": "Priority Front-Load Layer",
      "purpose": "Put the most actionable answer, status, verdict, or next step near the top instead of burying it."
    },
    {
      "layer": 2,
      "name": "Synthesis Layer",
      "purpose": "Combine work outputs, evidence, validator results, review notes, and context into one coherent final response."
    },
    {
      "layer": 3,
      "name": "Formatting & Copy/Paste Layer",
      "purpose": "Shape outputs into usable copy/paste blocks, reports, prompts, tables, or deliverable-ready structures."
    },
    {
      "layer": 4,
      "name": "Proof & Traceability Layer",
      "purpose": "Attach changed files, validator results, commit hashes, evidence, assumptions, and uncertainty notes where needed."
    },
    {
      "layer": 5,
      "name": "Audience Adaptation Layer",
      "purpose": "Adjust output for Devin, client, recruiter, portfolio, technical, operational, or public-facing use."
    },
    {
      "layer": 6,
      "name": "Version & Release Layer",
      "purpose": "Track versions, release notes, changelogs, labels, package names, and stable baselines."
    },
    {
      "layer": 7,
      "name": "Final Delivery Gate",
      "purpose": "Confirm that the output is complete, readable, scoped, validated, and ready for its intended use."
    }
  ],
  "global_rules": [
    "1. Preserve the locked 175-family baseline unless the user explicitly authorizes baseline mutation.",
    "2. Use overlays for Devinization unless explicitly instructed otherwise.",
    "3. Front-load the most important answer, verdict, or next action.",
    "4. Do not bury likely-wanted information at the bottom.",
    "5. Final answers must distinguish done, blocked, partial, failed, and next-step states.",
    "6. Repository final reports must include changed files, validator results, commit hash, and baseline-scope confirmation.",
    "7. Deliverables must be shaped for the intended audience.",
    "8. Copy/paste outputs must be complete enough to use without hidden setup.",
    "9. Prompts must preserve the user’s requested content and must not silently shorten important detail.",
    "10. Version labels must be clear and sequential when a project uses versioned outputs.",
    "11. Release notes must identify what changed, why it changed, and what remains.",
    "12. Changelogs must preserve meaningful decisions, fixes, and scope changes.",
    "13. Do not claim a file, report, release, or export is ready unless the proof layer supports it.",
    "14. When output is partial, say exactly what is complete, what is missing, and what the next command should be.",
    "15. When delivering check results, give a verdict first, then proof.",
    "16. Preserve the art piece: delivery intelligence makes the command civilization usable without shrinking it."
  ],
